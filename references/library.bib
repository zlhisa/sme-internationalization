  issn = {0883-2404},
  urldate = {2026-04-30},
  abstract = {As artificial intelligence (AI) becomes more prominent in the marketing and advertising fields, it is important to understand what consumers think of these technological advances. This study explores millennial views of AI in advertising. With little academic work on this topic, this exploratory study provides insight useful to advertising and marketing professionals, academics and the software engineers that design the technology. The purpose of this research is to learn more about millennial consumers attitudes toward AI technologies in advertising settings. Specifically, this research examines 1) what millennial consumers know about AI in advertising and 2) what attitudes toward AI in advertising do millennials hold. Using a qualitative interview method, this study identified three attitudes that are useful to understanding how millennials feel towards AI being used in advertising: generally negative, generally positive and creepy but convenient. The findings are explained through the lens of the Technology Acceptance Model (TAM). In particular, perceived difficulty of disengaging is considered to be a new construct that can be used to uncover millennials attitudinal and behavioral responses toward using AI in advertising. Theoretical and practical implications are discussed.},
  copyright = {Copyright American Academy of Advertising 2020},
  langid = {english},
  keywords = {Advertising,Artificial intelligence,Attitudes,Consumer behavior,Market research,Marketing,Millennials,Technology Acceptance Model},
  file = {/Users/lisa/Zotero/storage/NEVX4SHR/Obrzut et al. - 2020 - Millennials' Attitudes Toward Artificial Intelligence in Advertising A Qualitative Study.pdf}
}

