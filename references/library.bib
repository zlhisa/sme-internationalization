@article{busserInvolvementConsumergeneratedAdvertising2019,
  title = {Involvement in Consumer-Generated Advertising:~{{Effects}} of Organizational Transparency and Brand Authenticity on Loyalty and Trust},
  shorttitle = {Involvement in Consumer-Generated Advertising},
  author = {Busser, James A. and Shulga, Lenna V.},
  year = 2019,
  journal = {International Journal of Contemporary Hospitality Management},
  volume = {31},
  number = {4},
  pages = {1763--1784},
  publisher = {Emerald Group Publishing Limited},
  address = {Bradford, United Kingdom},
  issn = {09596119},
  doi = {10.1108/IJCHM-10-2017-0685},
  urldate = {2026-04-30},
  abstract = {Purpose The purpose of this paper is to examine consumer involvement with a popular US-based coffee-shop brand consumer-generated advertising (CGA) and its effect on brand loyalty and trust, to test the influence of antecedents: organizational transparency and brand authenticity on CGA involvement, and to analyze differences among customers and non-customers of the brand. Grounded in the service-dominant logic and signaling theory, a scenario-based survey describing a contest to co-create a video commercial, as CGA, for a prominent US-based coffee-shop brand, yielded 492 responses from recent restaurant patrons. Structural equation modeling was used to test the effects of involvement in CGA on loyalty and trust. Multi-group comparison examined the differences between customers and non-customers of the brand. Involvement in CGA had positive effects on loyalty and trust for both brand customers and non-customers. Transparency builds perceptions of brand authenticity; both authenticity and transparency significantly and positively affected trust, but only authenticity influenced loyalty. There was a stronger impact of involvement with CGA on loyalty for non-customers than brand customers. Non-customer perceptions of the brand's authenticity influenced brand trust more significantly than customer perceptions. Coffee-shop brand marketers should leverage online and physical brand exposure to involve both customers and non-customers in company-driven CGA, as a relationship management and marketing tool. Marketers should enhance transparency, which builds perceptions of brand authenticity, leading to greater CGA involvement. This study contributes to hospitality research and literature, revealing that non-customers can be converted to brand customers through authenticity and indirect involvement with CGA, leading to long-term relational outcomes. The results identified consumers' perception of organizational transparency is an antecedent of brand authenticity and established CGA contests as a relational marketing tool for hospitality brands.},
  copyright = {\copyright{} Emerald Publishing Limited 2019},
  langid = {english},
  keywords = {Advertising,Authenticity,Brand authenticity,Collaboration,Communication,Consumer,Consumer behavior,Consumer-generated advertising,Consumers,Credibility,Customer feedback,Customer services,Empowerment,Hospitality industry,Loyalty,Marketing,Perceptions,Purchase intention,Research,Social networks,Structural equation modeling,Tourism,Transparency,Trust,User generated content,Values},
  file = {/Users/lisa/Zotero/storage/F9BMCKMN/Busser and Shulga - 2019 - Involvement in consumer-generated advertising Effects of organizational transparency and brand auth.pdf}
}

