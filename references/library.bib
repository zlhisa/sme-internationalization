  issn = {0883-2404},
  urldate = {2026-04-30},
  abstract = {With generative AI(GAI) transforming the workflow and practices in the advertising and marketing communication landscape, it is of crucial importance to discuss the opportunities, challenges, as well as the ethical implications of these GAI applications in professional practices, education, and research domains. Powered by generative artificial intelligence (AI) and leveraging personal data, advertising practices have been revolutionized with more hyper-personalized content, such as Coca-Cola's "Create Real Magic" campaign. In addition, the rise of generative AI technology has profoundly influenced the landscape of advertising education and research practices. Its capacity to produce captivating content - from data analysis and consumer insight reporting to ad copy creation and idea generation - empowers advertising students, educators, and researchers. They can harness various AI tools to develop, explore, and choose more effective and informed advertising strategies. The half-day pre-conference was thus composed of two 90-minute sessions. The first session discussed the employment of generative AI in the industry, and also the ethical and legal conundrums it presents in die industry. The second session turned the spotlight on how generative AI technologies have been integrated into advertising education and research.},
  copyright = {Copyright American Academy of Advertising 2024},
  langid = {english},
  keywords = {Advertising,Business ethics,Ethics,Generative artificial intelligence,Marketing,Mass communications,Technology adoption},
  file = {/Users/lisa/Zotero/storage/65A29LND/Feng and Yang - 2024 - Pre-Conference Session Opportunities, Challenges, and Ethical Implications of Generative Artificial.pdf}
}

@article{fluhrerRoleStorytellingBranding2025,
  title = {The Role of Storytelling in the Branding of {{SMEs}}},
  author = {Fluhrer, Peter},
  year = 2025,
  journal = {Journal of Brand Management},
  publisher = {Palgrave Macmillan},
  issn = {1350-231X},
  doi = {10.1057/s41262-025-00418-8},
  abstract = {Storytelling presents a promising approach to building a strong brand. While the impact of storytelling on brand perception has been well researched from a consumer perspective, few studies have examined how SME entrepreneurs apply this concept. This study contributes to closing this research gap by exploring the role that brand storytelling plays in small businesses and how it mediates the relationship between brand identity and brand performance. A unique dataset of 217 German SMEs, including 107 effective responses from German start-ups, provided the basis for this study. For data analysis, this study used linear and multiple regressions for hypothesis testing and applied t-tests and one-way ANOVA to explore differences between start-ups and SMEs, as well as other factors like firm age and size. The results showed strong relations between brand storytelling and brand positioning which serves as the bridge between a brand's identity and its perception by customers. This is the first study to explore brand storytelling by distinguishing and empirically validating two dimensions: strategic storytelling (i.e. the brand as a story) and tactical storytelling (i.e. stories about the brand). Additionally, it provides practical implications for SME entrepreneurs on utilizing brand storytelling to enhance SME branding efforts. \copyright{} The Author(s) 2025.},
  langid = {english},
  keywords = {Brand identity and communication,Brand management,Brand storytelling,New ventures,Small and medium-sized enterprises (SME),Start-ups},
  file = {/Users/lisa/Zotero/storage/6U6VPD55/Fluhrer - 2025 - The role of storytelling in the branding of SMEs.pdf;/Users/lisa/Zotero/storage/IUHBRT83/105020882749.html}
