@article{qadriTheyMadeIt2026,
  title = {They {{Made It Just}} for {{Me}}! {{How AI Transparency}} and {{Influencer Well-Being Shape Consumer Responses}} to {{AI-Driven Content}}},
  author = {Qadri, Usman Ahmad and Moustafa, Alsadig Mohamed Ahmed},
  year = 2026,
  journal = {Psychology \& Marketing},
  volume = {43},
  number = {3},
  pages = {591--608},
  issn = {1520-6793},
  doi = {10.1002/mar.70075},
  urldate = {2026-04-28},
  abstract = {This study investigates how AI-driven content personalization in influencer marketing shapes consumer purchase intentions, focusing on perceived authenticity as a mediator and AI transparency and influencer well-being as moderators. Grounded in the Theory of Reasoned Action (TRA), we argue that personalization enhances behavioral intentions primarily when followers perceive the endorsement as genuine, and this judgment is conditioned by disclosure about the algorithm's involvement and the influencer's apparent emotional state. Using a two-study design, we test a moderated-mediation model. Study 1, a 2 \texttimes{} 2 experiment (n = 280), varied AI transparency and influencer well-being and shows that perceived authenticity carries the effect of personalization to intentions. Study 2, a recall-based survey (n = 370), corroborates these relationships in naturalistic settings while accounting for respondents' familiarity with AI. Results from both studies confirm that perceived authenticity significantly mediates the relationship between personalization and purchase intentions. The indirect effect is strengthened when AI transparency is high and when influencer well-being is low, suggesting that consumers interpret transparency and emotional cues as signals of sincerity. These findings extend TRA to digital content environments by demonstrating that personalization alone is insufficient to generate persuasive outcomes without the support of credibility-enhancing cues.},
  langid = {english},
  keywords = {AI influencer marketing,AI transparency,AI-driven personalization,influencer well-being,perceived authenticity,purchase intentions},
  file = {/Users/lisa/Zotero/storage/DDHHEI93/Qadri and Moustafa - 2026 - They Made It Just for Me! How AI Transparency and Influencer Well-Being Shape Consumer Responses to.pdf;/Users/lisa/Zotero/storage/QH5WWREZ/mar.html}
}

@phdthesis{rapierBrandTrustConnection2013,
  title = {Brand Trust: {{The}} Connection between Behavioral Achieving Styles, Brand Authenticity, and the Consumer's Trust-Building Process},
  shorttitle = {Brand Trust},
  author = {Rapier, Stephen M.},
  year = 2013,
  journal = {ProQuest Dissertations and Theses},
  address = {United States -- California},
  urldate = {2026-04-30},
  abstract = {Modern brands are more than mere symbols or logos. Today, they embody entire organizations exerting their influence in pursuits related to business, politics, entertainment, athletics, non-profit, government, and education. Consumers fuel this brand power through their brand commitment. While the duration of this commitment is sometimes limited to a low involvement, discrete transaction, it is often required to stretch through the ongoing interaction of a high involvement, relational exchange. In either case, consumers expect that brands will reciprocate for their commitment by acting in their best interest. The consumer is aware, however, that this expectation is not always met. This potential for disappointment prompts the consumer's uncertainty about his/her relationship with the brand, requiring him/her to trust the brand before he/she can commit to it. Given the competitive pressure for brands to gain the consumer's trust, the brand literature has investigated the consumer's trust-building process. While calling attention to the role of brand behavior and authenticity in the trust-building process, however, their characterization was limited. Intrigued by this gap, this researcher sought insight into the consumer's trust-building process from a body of literature where trust is equally important in the relationship between two parties: leadership. This study introduces the Connective Leadership Model (Lipman-Blumen, 1996) in an inaugural test of a theoretical model investigating the similarity between the consumer's trust-building process in a high involvement, relational exchange and that of a follower. The results of this investigation support the comparability between the trust-building process of consumers and that of followers. For instance, just as a follower finds behavioral similarities with a chosen leader reassuring, the researcher conjectured that a consumer finds behavioral similarities with a chosen brand reassuring. The study's results corroborated the hypothesis that a consumer's behavior will resemble that rewarded by their chosen brand. Moreover, just as the leader's authenticity and behavioral similarities form the basis for the follower's trust in the leader, the researcher conjectured that the brand's genuineness forms the basis for the consumer's trust in the brand. The findings supported the proposition that the brand's authenticity and behavioral similarities explains the consumer's trust in the brand.},
  copyright = {Database copyright ProQuest LLC; ProQuest does not claim copyright in the individual underlying works.},
  isbn = {978-1-303-55621-0},
  langid = {english},
  school = {The Claremont Graduate University},
  keywords = {Actors,Advisors,Authenticity,Automobile dealers,Behavior,Behavioral achieving styles,Brand,Commitment,Confidence,Consumer,Consumers,Cooperation,Customer services,Demographics,Females,Hypotheses,Inventory,Investigations,Leadership,Literature reviews,Market research,Marketing,Perceptions,Social sciences,Standard deviation,Students,Success,Theater,Trust},
  file = {/Users/lisa/Zotero/storage/R8YYN5HN/Rapier - 2013 - Brand trust The connection between behavioral achieving styles, brand authenticity, and the consume.pdf}
}

@article{riandhiAIConsumerBehavior2025,
  title = {{{AI}} and Consumer Behavior: {{Trends}}, Technologies, and Future Directions from a Scopus-Based Systematic Review},
  shorttitle = {{{AI}} and Consumer Behavior},
  author = {Riandhi, Aditya Nanda and Arviansyah, Muhammad Rifqi and Sondari, Mery Citra},
  year = 2025,
  month = aug,
  journal = {Cogent Business \& Management},
  volume = {12},
  number = {1},
  pages = {2544984},
  publisher = {Cogent OA},
  issn = {null},
  doi = {10.1080/23311975.2025.2544984},
  urldate = {2026-04-29},
  abstract = {This systematic literature review, conducted following the PRISMA 2020 guidelines, synthesizes 117 Scopus-indexed articles (2009--April 4, 2025) to address six research questions on artificial intelligence's (AI) role in consumer behavior. The study examines research trends (RQ1), prevalent AI technologies (RQ2), key variables (RQ3), methodological approaches (RQ4), future research directions (RQ5), and AI's transformative impact on consumer behavior (RQ6). Findings report exponential publication surges after 2020, driven by machine learning and natural language processing applications. Consumer attitudes (trust, privacy) and behavioral intentions emerge as primary mediators of AI adoption, while ethical concerns underline the need for open algorithmic architectures. Quantitative survey methods dominate, though longitudinal and cross-cultural investigations remain infrequent. Generative AI is a disruptive technology enabling hyper-personalization but also authenticity threats. Practical implications call for ethical imperatives of AI governance and hybrid human-machine processes to weigh innovation against consumer trust. In noting limitations of geographic coverage and linguistic bias, the review proposes future research agendas like cultural mediation of AI acceptance and longitudinal behavioral impact. By examining these dimensions systematically, the research enhances academic understanding of AI's multifaceted influence and supports actionable insight to ethically grounded marketing practice in evolving technology contexts.},
  file = {/Users/lisa/Zotero/storage/AVHD2BDU/Riandhi et al. - 2025 - AI and consumer behavior Trends, technologies, and future directions from a scopus-based systematic.pdf}
}

@article{sahebiAIPenaltyDisclosure2026,
  title = {The {{AI}} Penalty and Disclosure Paradox: {{Trust}}, Authenticity and Knowledge Uptake in {{AI-mediated}} Communication},
  shorttitle = {The {{AI}} Penalty and Disclosure Paradox},
  author = {Sahebi, Siavosh and Formosa, Paul and Bankins, Sarah},
  year = 2026,
  month = may,
  journal = {Computers in Human Behavior: Artificial Humans},
  volume = {8},
  pages = {100304},
  issn = {2949-8821},
  doi = {10.1016/j.chbah.2026.100304},
  urldate = {2026-04-28},
  abstract = {As Artificial Intelligence is increasingly employed to mediate human interactions, there is uncertainty around how these technologies impact human behaviour and how such mediated interactions are perceived. One such case is the expanding use of Generative Artificial Intelligence (GenAI) to create and disseminate content across a range of media contexts, known as AI-Mediated Communication (AI-MC). Such cases raise important questions about how those on the receiving end of such outputs respond to these new forms of interpersonal communications. Based on evaluating a piece of written text, this study explores how recipients' perceptions of the content creator's trustworthiness and authenticity, alongside their willingness to use the content (via knowledge uptake) are impacted by author type (human, AI-assisted, or fully AI) and media context (workplace email vs. social media post). We conducted a pre-registered experimental survey study with a 3 (author type) x 2 (media context) between-subjects factorial design (N~=~547) where participants evaluated a piece of written text. Our findings demonstrate an ``AI penalty'', with communication involving AI being perceived as less trustworthy, less authentic, and less useful for knowledge uptake. We also identify a ``disclosure paradox'', as while participants believed it is important to disclose AI use, they also penalise the communication when such disclosure is made, which risks creating perverse incentives for non-disclosure of GenAI use for written communications.},
  keywords = {AI ethics,AI mediated communication (AI-MC),Artificial intelligence (AI),Disclosure,Trust and AI},
  file = {/Users/lisa/Zotero/storage/8KHDX77V/Sahebi et al. - 2026 - The AI penalty and disclosure paradox Trust, authenticity and knowledge uptake in AI-mediated commu.pdf;/Users/lisa/Zotero/storage/R6LBSLEV/S2949882126000551.html}
}

